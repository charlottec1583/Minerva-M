# ==============================================================================
# API Configuration
# ==============================================================================
# Three categories: TARGET, ATTACK, EVALUATION
# Split Character: All lists use comma (,) as the split character
# ==============================================================================

# ===== TARGET Configuration (Primary/Default) =====
# Used for: Target model being attacked
# Also used as fallback for ATTACK and EVALUATION if not specified
# Split Character: comma (,)
# Example: model1,model2,model3
TARGET_MODEL_LIST=
TARGET_BASE_URL_LIST=
TARGET_API_KEY_LIST=
# Provider options: "openai" or "azure"
# Default: "openai" (or auto-detected from base_url)
TARGET_PROVIDER_LIST=
# Deployment name (for Azure) or model identifier
TARGET_DEPLOYMENT_LIST=
# API version (for Azure, default: 2025-04-01-preview)
TARGET_API_VERSION_LIST=

# ===== ATTACK Configuration =====
# Used for: Attack agent model (planner & generator)
# Falls back to TARGET_* if not set
# Split Character: comma (,)
ATTACK_MODEL_LIST=
ATTACK_BASE_URL_LIST=
ATTACK_API_KEY_LIST=
ATTACK_PROVIDER_LIST=
ATTACK_DEPLOYMENT_LIST=
ATTACK_API_VERSION_LIST=

# ===== EVALUATION Configuration =====
# Used for: Evaluation/judge model
# Falls back to TARGET_* if not set
# Split Character: comma (,)
EVALUATION_MODEL_LIST=
EVALUATION_BASE_URL_LIST=
EVALUATION_API_KEY_LIST=
EVALUATION_PROVIDER_LIST=
EVALUATION_DEPLOYMENT_LIST=
EVALUATION_API_VERSION_LIST=

# ===== Workflow Configuration =====
# Maximum subgraph iterations for each attack step
# Default: 5
# Recommended: 3-5 (higher = more attempts but slower)
MAX_SUBGRAPH_ITERATIONS=5

# ===== Multi-Layer Retry Architecture =====
# Retry hierarchy (from outermost to innermost):
#   Layer 3: AGENT_MAX_RETRY_NUM    - Retry Agent.invoke() if it fails
#   Layer 2: LLM_MAX_RETRIES        - Retry LLM SDK HTTP requests
#   Layer 1: LLM_REQUEST_TIMEOUT    - Single HTTP request timeout
#
# These parameters work at different layers and do NOT overlap.
# They form a multi-layer defense against transient failures.
# See main_batch_test.py for detailed implementation.

# Layer 3: Agent-level retry (BasicAgent retry mechanism)
# When: After LLM SDK retries are exhausted, BasicAgent retries the entire agent call
# Location: jailbreak_core/BasicAgent.py:209
# Default: Retry 6 times with exponential backoff (1.5s → 12s max, factor 1.8)
AGENT_MAX_RETRY_NUM=6
AGENT_INVOKE_DELAY=1.5
AGENT_INVOKE_DELAY_MAX=12.0
AGENT_RETRY_BACKOFF_FACTOR=1.8

# Layer 2 & 1: LLM SDK-level retry (LangChain ChatOpenAI retry mechanism)
# When: HTTP/SDK errors during API calls
# Location: LangChain's ChatOpenAI (delegated to httpx library)
# Default: 120s timeout per request, 2 SDK-level retries
LLM_REQUEST_TIMEOUT=120
LLM_MAX_RETRIES=2

# ===== Dataset Configuration =====
# Dataset name to use for batch testing
# Available options: "advbench", "tdc2023", "maliciousinstruct",
#                    "harmbench_val", "harmbench_test", "jailbreakbench",
#                    "strongreject", "alpaca" (**harmless**)
DATASET_NAME=harmbench_test

# ===== Batch Test Configuration =====
# Maximum number of samples to test (set to a large number like 999999 for all samples)
# Recommended for quick testing: 5-10
# Recommended for full evaluation: 999999
MAX_SAMPLES=5
# Starting index in the dataset
# Useful for resuming interrupted tests or parallel testing
SAMPLES_START_INDEX=0

# ===== Attack Success Threshold =====
# The threshold required to consider an attack successful
ATTACK_SUCCESS_SCORE_THRESHOLD=5

# ===== GA Optimization Configuration =====
# Enable GA mode for strategy optimization
# GA mode will significantly increase runtime (population_size × max_generations per sample)
USE_GA_MODE=true

# GA Parameters
# Population size: Number of individuals in each generation
# Recommended: 5-20 for testing, 20-50 for production
GA_POPULATION_SIZE=5

# Mutation rate: Probability of gene mutation (0.0-1.0)
# Recommended: 0.2-0.4
GA_MUTATION_RATE=0.3

# Crossover rate: Probability of gene crossover (0.0-1.0)
# Recommended: 0.6-0.8
GA_CROSSOVER_RATE=0.7

# Max generations: Maximum number of generations to evolve
# Recommended: 3-5 for quick testing, 5-10 for optimization
GA_MAX_GENERATIONS=3

# Fitness threshold: Early termination when fitness reaches this value
# Score range: 0-10 (5 = attack success)
GA_FITNESS_THRESHOLD=5

# Ablation mode for strategy space configuration
# Options: "original", "no_constraints", "core_protected_only", "leakage_excluded_only", "all_core"
# - original: Use full strategy space (default)
# - no_constraints: Remove constraint-related strategies
# - core_protected_only: Only use core protected strategies
# - leakage_excluded_only: Exclude leakage strategies
# - all_core: Use all core strategies
GA_ABLATION_MODE=original

# ===== Stage Visibility Configuration =====
# Control whether stage information is revealed to workflow nodes (planner, generator, judge)
# Set to "true" to reveal stage information (default)
# Set to "false" to hide stage information from all nodes (for ablation studies)
# When false: nodes see "[hidden]" instead of actual stage names like "context_establishment"
REVEAL_STAGE_TO_NODES=true
